# ─────────────────────────────────────────────────────────────────────────────
# JSM Home Assistant Notifier — Environment Configuration
#
# 1. Copy this file to .env:
#      cp .env.example .env
#
# 2. Fill in every required value below.
#
# 3. Run the service:
#      docker compose up -d
#
# ⚠️  NEVER commit .env to git — it contains secrets.
#     .gitignore already excludes it, but double-check before pushing.
# ─────────────────────────────────────────────────────────────────────────────


# ── Atlassian / JSM ──────────────────────────────────────────────────────────

# Atlassian API base URL — do not change this unless Atlassian moves it.
JSM_API_URL=https://api.atlassian.com

# Your Atlassian Cloud ID.
# How to find it:
#   curl -s -u "you@yourcompany.com:YOUR_API_TOKEN" \
#     https://your-org.atlassian.net/_edge/tenant_info \
#     | python3 -m json.tool
#   Look for the "cloudId" field.
JSM_CLOUD_ID=your-cloud-id-here

# Atlassian account email used to authenticate API calls.
# This is the email address you use to log into Atlassian.
JSM_USERNAME=you@yourcompany.com

# Atlassian API token.
# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
#   1. Click "Create API token"
#   2. Give it a descriptive label (e.g. "JSM HA Notifier")
#   3. Copy the token — you won't be able to see it again
#
# The token must have access to JSM Ops (OpsGenie) schedules.
JSM_API_TOKEN=your-atlassian-api-token-here

# Your Atlassian account ID (the "accountId" value in Atlassian's API).
# This is used to check whether YOU are currently on-call for a schedule.
# How to find it:
#   Option A — call the JSM on-calls endpoint for a schedule and look for your
#   name in the "onCallParticipants" array; the "id" field is your account ID.
#
#   Option B — if you have an existing on-call script, look for a USERID or
#   accountId variable — that value is your account ID.
#
#   Option C — search for "accountId" in your browser's network traffic while
#   logged into Atlassian (dev tools → Network tab → search responses).
JSM_MY_USER_ID=your-atlassian-account-id-here


# ── Schedule routing ─────────────────────────────────────────────────────────
#
# The service supports two routing modes:
#
#   ALWAYS_NOTIFY_SCHEDULE_NAMES
#     Schedules that should ALWAYS trigger a TTS announcement and HA
#     notification, regardless of whether you are currently on-call.
#     Point the JSM webhook URL to:  https://your-host:8080/alert?mode=always
#
#   CHECK_ONCALL_SCHEDULE_NAMES
#     Schedules that only notify you when you are currently on-call.
#     The service queries JSM in real time and caches the result for
#     ONCALL_CACHE_TTL_SECONDS seconds.
#     Point the JSM webhook URL to:  https://your-host:8080/alert
#
# Both accept a comma-separated list of schedule names exactly as they appear
# in JSM, or a JSON array.  Leave empty if you have no schedules of that type.
#
# How to find your exact schedule names:
#   curl -s -u "you@yourcompany.com:YOUR_API_TOKEN" \
#     "https://api.atlassian.com/jsm/ops/api/YOUR_CLOUD_ID/v1/schedules" \
#     | python3 -m json.tool | grep '"name"'
#
# Names are case-sensitive and must match exactly.
#
# Examples (replace with your actual schedule names):
#   ALWAYS_NOTIFY_SCHEDULE_NAMES=Infrastructure Alerts
#   CHECK_ONCALL_SCHEDULE_NAMES=Engineering On-Call Schedule
#   CHECK_ONCALL_SCHEDULE_NAMES=Primary On-Call,Secondary On-Call
ALWAYS_NOTIFY_SCHEDULE_NAMES=
CHECK_ONCALL_SCHEDULE_NAMES=


# ── Home Assistant ───────────────────────────────────────────────────────────

# External (or LAN) URL to your Home Assistant instance.
# Include the port if not using standard 80/443.
# Examples:
#   HA_URL=https://homeassistant.local:8123
#   HA_URL=https://ha.yourdomain.com
HA_URL=https://homeassistant.local:8123

# Long-lived access token for the Home Assistant REST API.
# How to create one:
#   1. In HA, click your profile picture (bottom-left)
#   2. Scroll to "Security" → "Long-Lived Access Tokens"
#   3. Click "Create token", give it a name (e.g. "JSM Notifier")
#   4. Copy the token — it is only shown once
HA_TOKEN=your-home-assistant-long-lived-access-token-here

# entity_id of the media player (Google Home, Chromecast, etc.) to announce on.
# How to find it:
#   In HA, go to Developer Tools → States, filter by "media_player".
#   The entity_id looks like: media_player.living_room or media_player.kitchen_hub
HA_MEDIA_PLAYER_ENTITY=media_player.living_room

# TTS service to use for announcements.
# Common options:
#   tts.home_assistant_cloud   — Nabu Casa (requires active subscription)
#   tts.google_translate       — Free, lower quality
#   tts.piper                  — Free, local, requires Piper add-on
# Check available services: HA → Developer Tools → Services → search "tts"
HA_TTS_SERVICE=tts.home_assistant_cloud

# BCP-47 language/locale tag passed to the TTS service.
# Common values: en-US, en-GB, en-AU
# Check your TTS service documentation for supported languages.
HA_TTS_LANGUAGE=en-US

# Voice name supported by your TTS provider.
# For Home Assistant Cloud (Nabu Casa), find voice names at:
#   https://www.home-assistant.io/integrations/cloud/#text-to-speech
# Common English voices: JennyNeural, AriaNeural, GuyNeural, DavisNeural
# For Google Translate, this field is ignored.
HA_TTS_VOICE=JennyNeural

# Label shown as the "artist" field in the HA media player UI when an alert
# is playing.  Customise to your company name or team name.
# Defaults to "JSM Alert Notifier" if not set.
HA_NOTIFIER_LABEL=JSM Alert Notifier


# ── Webhook security ─────────────────────────────────────────────────────────

# Optional shared HMAC-SHA256 secret for verifying inbound JSM webhooks.
#
# If set, every inbound POST to /alert must include:
#   X-Hub-Signature-256: sha256=<hex-hmac-of-raw-body>
#
# Generate a strong secret (macOS/Linux):
#   openssl rand -hex 32
#
# Then configure JSM to send this header on its outgoing webhook:
#   In JSM → Webhook Integration → Headers, add:
#     Name:  X-Hub-Signature-256
#     Value: sha256={{ hmac_sha256(body, "YOUR_SECRET_HERE") }}
#            (exact Jinja syntax may vary by JSM version — check Atlassian docs)
#
# Leave empty to disable signature verification.
# ⚠️  Only acceptable if the service is on a private network with no internet
#     exposure.  Always set this if JSM reaches your service over the internet.
WEBHOOK_SECRET=

# Optional API key for authenticating requests.  If set, all authenticated
# endpoints require a valid key or receive a 401 Unauthorized.
#
# The key can be passed via any of these methods (all work on every endpoint):
#
#   1. Query parameter:   https://your-host/alert?key=YOUR_KEY
#   2. URL path prefix:   https://your-host/YOUR_KEY/alert
#   3. HTTP header:       X-API-Key: YOUR_KEY
#
# Method 1 is best for JSM webhooks (URL-only config).
# Method 2 works with tools that can't add headers or query params.
# Method 3 is preferred for scripts, HA automations, and Grafana.
#
# You can use BOTH WEBHOOK_SECRET and WEBHOOK_API_KEY together for defense in
# depth, or just one.
#
# Generate a strong key (macOS/Linux):
#   openssl rand -hex 32
#
# NOTE: When set, endpoints return 404 (not 401) for missing/wrong keys.
# This prevents attackers from discovering that endpoints exist.
# See the Troubleshooting section in README.md if you get unexpected 404s.
#
# Leave empty to disable API key checking.
WEBHOOK_API_KEY=


# ── Emoji control ─────────────────────────────────────────────────────────────
#
# When true (default), priority emojis (🔴 🟠 🟡 🟢 ⚪) appear in HA
# notification titles and media player metadata (e.g. "🔴 P1: Server down").
#
# When false, ALL emojis are removed from output — both internal ones (priority
# indicators, escalation arrows) and any emojis arriving in the alert text from
# JSM or other webhook sources.  Useful if your HA setup doesn't render emojis
# well, or if you prefer plain-text notifications.
#
#   ENABLE_EMOJIS=true    ← default (emojis on)
#   ENABLE_EMOJIS=false   ← strip all emojis
ENABLE_EMOJIS=true


# ── Announcement format ──────────────────────────────────────────────────────
#
# Customise the spoken TTS announcement using Python format-string placeholders.
#
# Available placeholders:
#   {action_prefix}    – "Escalated alert!" or "Attention!"
#   {priority}         – spoken priority, e.g. "Priority 1, Critical"
#   {message}          – alert title / summary from JSM
#   {entity}           – system / host name (empty string if absent)
#   {description}      – truncated description text (empty string if absent)
#   {entity_part}      – " System: <entity>." or "" if no entity
#   {description_part} – " Details: <description>." or "" if no description
#
# Default (detailed) format — matches the original built-in announcement:
#   ANNOUNCEMENT_FORMAT={action_prefix} {priority} alert from Jira Service Management. Alert: {message}.{entity_part}{description_part}
#
# Terse format — used during terse time windows (see below):
#   TERSE_ANNOUNCEMENT_FORMAT={action_prefix} {priority} alert. {message}.
#
# Examples:
#   ANNOUNCEMENT_FORMAT={action_prefix} {priority}. {message}. {entity}.
#   TERSE_ANNOUNCEMENT_FORMAT=Alert: {message}.
ANNOUNCEMENT_FORMAT={action_prefix} {priority} alert from Jira Service Management. Alert: {message}.{entity_part}{description_part}
TERSE_ANNOUNCEMENT_FORMAT={action_prefix} {priority} alert. {message}.


# ── Timezone ──────────────────────────────────────────────────────────────────
#
# The container defaults to UTC.  Set TZ to your local timezone so that
# silent/terse time windows and log timestamps match your wall clock.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
#
# Examples:
#   TZ=America/New_York
#   TZ=Europe/London
#   TZ=Asia/Tokyo
TZ=America/New_York


# ── Time windows (quiet hours) ──────────────────────────────────────────────
#
# Control TTS announcement verbosity by time of day.  Each value is a
# comma-separated list of HH:MM-HH:MM windows.  Windows that cross midnight
# are fully supported (e.g. 22:30-07:00).
#
# IMPORTANT: Times are evaluated in the container's local timezone (set by TZ).
#
# SILENT_WINDOW — During these hours, NO TTS announcement is played.
#   The persistent dashboard notification is still created so you don't miss
#   anything; only the audio is suppressed.
#
# TERSE_WINDOW — During these hours, the short/terse TTS format is used
#   instead of the full announcement.  Useful for early mornings when you
#   want to be woken up but don't need every detail read aloud.
#
# If a time falls inside both a silent AND a terse window, silent wins.
#
# Leave empty (the default) to disable — all announcements are full verbosity.
#
# Examples:
#   Silence overnight, terse in the early morning:
#     SILENT_WINDOW=23:00-06:00
#     TERSE_WINDOW=06:00-08:00
#
#   Multiple windows (comma-separated):
#     SILENT_WINDOW=23:00-06:00, 12:00-13:00
#     TERSE_WINDOW=06:00-08:00, 20:00-21:00
#
#   Window that crosses midnight:
#     SILENT_WINDOW=22:30-07:00
#
SILENT_WINDOW=
TERSE_WINDOW=

# Priorities that bypass silent mode — even during a silent window, these
# priorities will ALWAYS play a TTS announcement so you don't sleep through
# a critical incident.  Comma-separated.
# Leave empty (default) to silence ALL priorities during silent windows.
#
# Examples:
#   SILENT_WINDOW_OVERRIDE_PRIORITIES=P1
#   SILENT_WINDOW_OVERRIDE_PRIORITIES=P1,P2
SILENT_WINDOW_OVERRIDE_PRIORITIES=


# ── Media player routing ─────────────────────────────────────────────────────
#
# Route TTS announcements to different speakers based on time of day.
# The default HA_MEDIA_PLAYER_ENTITY is used when no routing entry matches.
#
# Format: comma-separated entries of entity@HH:MM-HH:MM
# Cross-midnight windows are supported (e.g. 22:00-08:00).
#
# Examples:
#   Night announcements on bedroom speaker, daytime on office:
#     HA_MEDIA_PLAYER_ROUTING=media_player.bedroom@22:00-08:00, media_player.office@08:00-18:00
#
#   Only override at night; all other times use HA_MEDIA_PLAYER_ENTITY:
#     HA_MEDIA_PLAYER_ROUTING=media_player.bedroom@23:00-07:00
#
# Leave empty (default) to always use HA_MEDIA_PLAYER_ENTITY.
HA_MEDIA_PLAYER_ROUTING=


# ── Volume control ───────────────────────────────────────────────────────────
#
# Set the media player volume before each TTS announcement.
# Values are 0.0 (mute) to 1.0 (max).  Leave empty to skip volume adjustment
# and use whatever the player's current volume is.
#
# HA_VOLUME_DEFAULT — volume for full (normal) announcements.
# HA_VOLUME_TERSE   — volume for terse announcements (typically lower).
#                     Falls back to HA_VOLUME_DEFAULT if not set.
#
# Examples:
#   Full volume during the day, quieter terse announcements:
#     HA_VOLUME_DEFAULT=0.7
#     HA_VOLUME_TERSE=0.4
#
#   Same volume for everything:
#     HA_VOLUME_DEFAULT=0.5
HA_VOLUME_DEFAULT=
HA_VOLUME_TERSE=


# ── Alert batching ───────────────────────────────────────────────────────────
#
# When multiple alerts fire within a short time window, batch them into a
# single TTS announcement instead of playing back-to-back messages.
# The value is the number of seconds to wait for additional alerts before
# announcing.  Set to 0 (default) to disable batching and announce immediately.
#
# How it works:
#   1. First alert arrives → a timer starts for this many seconds.
#   2. Any alerts arriving during the window are queued.
#   3. When the timer fires, all queued alerts are announced as one TTS message.
#   4. Persistent notifications are still created individually.
#
# Examples:
#   ALERT_BATCH_WINDOW_SECONDS=10    # Wait 10 seconds for more alerts
#   ALERT_BATCH_WINDOW_SECONDS=0     # Disabled (default) — announce immediately
ALERT_BATCH_WINDOW_SECONDS=0


# ── TTS repeat (pager mode) ─────────────────────────────────────────────────
#
# For critical alerts, repeat the TTS announcement at regular intervals until
# the alert is acknowledged or closed in JSM (or the max repeat count is hit).
# This mimics the behavior of a traditional pager that keeps beeping until ack.
#
# TTS_REPEAT_INTERVAL_SECONDS — seconds between each repeat (0 = disabled).
# TTS_REPEAT_MAX              — maximum number of repeats before giving up.
# TTS_REPEAT_PRIORITIES       — which priorities trigger repeats (comma-separated).
#
# Examples:
#   Repeat P1 alerts every 2 minutes, up to 5 times:
#     TTS_REPEAT_INTERVAL_SECONDS=120
#     TTS_REPEAT_MAX=5
#     TTS_REPEAT_PRIORITIES=P1
#
#   Repeat P1 and P2 alerts every 90 seconds, up to 10 times:
#     TTS_REPEAT_INTERVAL_SECONDS=90
#     TTS_REPEAT_MAX=10
#     TTS_REPEAT_PRIORITIES=P1,P2
#
#   Disable repeats (default):
#     TTS_REPEAT_INTERVAL_SECONDS=0
TTS_REPEAT_INTERVAL_SECONDS=0
TTS_REPEAT_MAX=5
TTS_REPEAT_PRIORITIES=P1


# ── Alert acknowledgment from Home Assistant ─────────────────────────────────
#
# The service exposes a REST endpoint that lets you acknowledge JSM alerts
# directly from Home Assistant — no need to open the JSM web UI.
#
#   POST /alert/{alert_id}/acknowledge
#
# When called, the service:
#   1. Acknowledges the alert in JSM via the Ops API.
#   2. Dismisses the persistent HA dashboard notification.
#   3. Cancels any pending TTS repeat for that alert.
#
# Usage in Home Assistant:
#   Create a REST command in your configuration.yaml:
#
#   rest_command:
#     acknowledge_jsm_alert:
#       url: "http://your-notifier-host:8080/alert/{{ alert_id }}/acknowledge"
#       method: POST
#       content_type: "application/json"
#
#   Then create an automation or script that calls it:
#
#   service: rest_command.acknowledge_jsm_alert
#   data:
#     alert_id: "the-alert-id-from-the-notification"
#
# No additional .env configuration needed — the endpoint uses the existing
# JSM credentials (JSM_USERNAME, JSM_API_TOKEN, JSM_CLOUD_ID).


# ── HA automation webhooks ─────────────────────────────────────────────────────
#
# Trigger Home Assistant automations on specific alert lifecycle events.
# Each value is a webhook ID (or comma-separated list) that the notifier will
# POST to HA's /api/webhook/{id} endpoint.  The HA automation then handles
# the visual/audible response (flash lights, change colors, activate scenes).
#
# HA webhooks don't require authentication — they use HA's built-in webhook
# trigger.  The notifier sends the alert data as JSON in the POST body, which
# becomes available as trigger variables in the automation.
#
# Trigger variables available in your HA automation:
#   trigger.json.event       — action name (Create, EscalateNext, Acknowledge, etc.)
#   trigger.json.alert_id    — unique alert identifier
#   trigger.json.message     — alert title / summary
#   trigger.json.priority    — P1–P5
#   trigger.json.entity      — system / host name
#   trigger.json.description — longer description text (first 200 chars)
#   trigger.json.source      — alert source
#   trigger.json.tags        — list of tags
#
# How to set up:
#   1. Create an automation in HA with a webhook trigger:
#        trigger:
#          - platform: webhook
#            webhook_id: "jsm_alert_created"
#            allowed_methods: [POST]
#            local_only: true
#   2. Add actions (flash a light, change color, activate scene, etc.)
#   3. Set the webhook ID here.
#
# JSM action mapping:
#   Create         → HA_WEBHOOK_ON_CREATE
#   EscalateNext   → HA_WEBHOOK_ON_ESCALATE
#   Acknowledge    → HA_WEBHOOK_ON_ACKNOWLEDGE
#   Close          → HA_WEBHOOK_ON_CLOSE
#   AddNote / Seen / AssignOwnership / UnAcknowledge → HA_WEBHOOK_ON_UPDATE
#   SlaBreached    → HA_WEBHOOK_ON_SLA_BREACH
#
# Examples:
#   Flash office light red on P1 create:
#     HA_WEBHOOK_ON_CREATE=jsm_alert_created
#
#   Multiple webhooks on escalation:
#     HA_WEBHOOK_ON_ESCALATE=jsm_escalation,flash_all_lights
#
#   Turn lights green on resolve:
#     HA_WEBHOOK_ON_CLOSE=jsm_alert_resolved
#
#   Flash yellow on SLA breach:
#     HA_WEBHOOK_ON_SLA_BREACH=jsm_sla_breached
#
# Leave empty to disable (default).
HA_WEBHOOK_ON_CREATE=
HA_WEBHOOK_ON_ESCALATE=
HA_WEBHOOK_ON_ACKNOWLEDGE=
HA_WEBHOOK_ON_CLOSE=
HA_WEBHOOK_ON_UPDATE=
HA_WEBHOOK_ON_SLA_BREACH=


# ── Incident dashboard ────────────────────────────────────────────────────────
#
# Enable a lightweight incident state dashboard at GET /incidents.
# Tracks all alert lifecycle events in a SQLite database so you can see
# current open incidents, their status, and history.
#
# The dashboard is updated automatically from incoming webhooks.  You can
# optionally enable periodic background sync from the JSM Ops API to catch
# alerts that were created/closed outside of webhook delivery.
#
# API endpoints (only active when enabled):
#   GET  /incidents          — list incidents (filterable: ?status=open&priority=P1)
#   GET  /incidents/summary  — aggregate counts by status and priority
#   GET  /incidents/{id}     — single incident detail
#   POST /incidents/sync     — force immediate JSM sync
#
# The JSON output is compatible with Grafana's JSON datasource plugin:
#   1. Install the "JSON" or "Infinity" datasource plugin in Grafana
#   2. Add datasource: URL = http://your-notifier:8080/incidents
#   3. Create panels using the incident data
#
# Set to true to enable.
INCIDENT_DASHBOARD_ENABLED=false

# Path to the SQLite database file.
# For ephemeral storage (lost on container restart): /tmp/incidents.db
# For persistent storage: mount a Docker volume and point here.
# Example docker-compose.yml:
#   volumes:
#     - ./data:/data
#   Then set: INCIDENT_DB_PATH=/data/incidents.db
INCIDENT_DB_PATH=/tmp/incidents.db

# How often (minutes) to sync open alerts from JSM in the background.
# This catches alerts that were created/modified outside of webhook delivery.
# Requires JSM API credentials to be configured.
# Set to 0 to disable background sync (only updates from webhooks).
# Examples:
#   INCIDENT_SYNC_INTERVAL_MINUTES=5    — sync every 5 minutes
#   INCIDENT_SYNC_INTERVAL_MINUTES=0    — disabled (default)
INCIDENT_SYNC_INTERVAL_MINUTES=0

# Retention policy: automatically delete stale incidents from the database.
# Runs during each sync cycle.  Set to 0 to keep forever (default).
#
# INCIDENT_RETENTION_OPEN_DAYS — delete open/escalated incidents older than
#   N days (stale incidents that were never resolved).
#
# INCIDENT_RETENTION_CLOSED_DAYS — delete closed/acknowledged incidents older
#   than N days (resolved incidents kept for historical reference).
#
# Examples:
#   Keep open incidents 30 days, closed 90 days:
#     INCIDENT_RETENTION_OPEN_DAYS=30
#     INCIDENT_RETENTION_CLOSED_DAYS=90
#
#   Keep everything forever:
#     INCIDENT_RETENTION_OPEN_DAYS=0
#     INCIDENT_RETENTION_CLOSED_DAYS=0
INCIDENT_RETENTION_OPEN_DAYS=0
INCIDENT_RETENTION_CLOSED_DAYS=0


# ── Tuning (optional — defaults shown) ───────────────────────────────────────

# Seconds to cache on-call status before re-querying JSM (default: 5 minutes).
# Shorter = more accurate but more API calls; longer = fewer calls but stale.
ONCALL_CACHE_TTL_SECONDS=300

# Seconds to suppress a duplicate {alertId + action} pair (default: 60 s).
# Prevents double-announcements if JSM retries the same webhook delivery.
# Note: Create and EscalateNext events have different dedup keys, so an
# escalation is never suppressed by a prior Create — escalations always pass through.
ALERT_DEDUP_TTL_SECONDS=60

# How often (hours) the service verifies the Atlassian API token is still valid.
# On failure: HA plays a TTS warning and creates a persistent dashboard notification.
# During SILENT_WINDOW hours the TTS is suppressed (notification still created).
# The first check runs 30 seconds after startup; subsequent checks on this interval.
TOKEN_CHECK_INTERVAL_HOURS=24
